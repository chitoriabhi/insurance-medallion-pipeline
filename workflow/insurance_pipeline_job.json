{
  "name": "ETL_pipeline",
  "email_notifications": {
    "no_alert_for_skipped_runs": false
  },
  "webhook_notifications": {},
  "timeout_seconds": 0,
  "max_concurrent_runs": 1,
  "tasks": [
    {
      "task_key": "generate_chunks",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/chittoriarocks@gmail.com/Bronze/generate_chunks_new",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {},
      "disabled": false
    },
    {
      "task_key": "process_tables",
      "depends_on": [
        {
          "task_key": "generate_chunks"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "for_each_task": {
        "inputs": "{{tasks.generate_chunks.values.chunks}}",
        "concurrency": 4,
        "task": {
          "task_key": "strategy_router",
          "run_if": "ALL_SUCCESS",
          "notebook_task": {
            "notebook_path": "/Workspace/Users/chittoriarocks@gmail.com/Bronze/strategy_router",
            "base_parameters": {
              "strategy": "{{input.strategy}}",
              "source_table": "{{input.source_table}}",
              "target_table": "{{input.target_table}}",
              "chunk_column": "{{input.chunk_column}}",
              "start_id": "{{input.start_id}}",
              "end_id": "{{input.end_id}}",
              "partition_column": "{{input.partition_column}}",
              "lower_bound": "{{input.lower_bound}}",
              "upper_bound": "{{input.upper_bound}}",
              "num_partitions": "{{input.num_partitions}}",
              "user": "{{input.user}}",
              "password": "{{input.password}}",
              "driver": "{{input.driver}}",
              "jdbc_url": "{{input.jdbc_url}}",
              "source_name": "{{input.source_name}}"
            },
            "source": "WORKSPACE"
          },
          "max_retries": 3,
          "min_retry_interval_millis": 60000,
          "retry_on_timeout": false,
          "disable_auto_optimization": false,
          "timeout_seconds": 0,
          "email_notifications": {},
          "webhook_notifications": {},
          "disabled": false
        }
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {},
      "disabled": false
    },
    {
      "task_key": "get_enabled_tables",
      "depends_on": [
        {
          "task_key": "process_tables"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/chittoriarocks@gmail.com/Silver/01_get_enabled_tables",
        "source": "WORKSPACE"
      },
      "max_retries": 2,
      "min_retry_interval_millis": 7200000,
      "retry_on_timeout": false,
      "disable_auto_optimization": false,
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {},
      "disabled": false
    },
    {
      "task_key": "for_each_table",
      "depends_on": [
        {
          "task_key": "get_enabled_tables"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "for_each_task": {
        "inputs": "{{tasks.get_enabled_tables.values.table_list}}",
        "concurrency": 4,
        "task": {
          "task_key": "process_silver_table",
          "run_if": "ALL_SUCCESS",
          "notebook_task": {
            "notebook_path": "/Workspace/Users/chittoriarocks@gmail.com/Silver/02_bronze_to_silver",
            "base_parameters": {
              "source_table": "{{input}}"
            },
            "source": "WORKSPACE"
          },
          "max_retries": 2,
          "min_retry_interval_millis": 60000,
          "retry_on_timeout": false,
          "disable_auto_optimization": false,
          "timeout_seconds": 0,
          "email_notifications": {},
          "webhook_notifications": {},
          "disabled": false
        }
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {},
      "disabled": false
    },
    {
      "task_key": "get_enabled_gold_tables",
      "depends_on": [
        {
          "task_key": "for_each_table"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/chittoriarocks@gmail.com/Gold_files/controllers/get_enabled_gold_tables",
        "source": "WORKSPACE"
      },
      "max_retries": 3,
      "min_retry_interval_millis": 60000,
      "retry_on_timeout": false,
      "disable_auto_optimization": false,
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {},
      "disabled": false
    },
    {
      "task_key": "For_Each_Task",
      "depends_on": [
        {
          "task_key": "get_enabled_gold_tables"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "for_each_task": {
        "inputs": "{{tasks.get_enabled_gold_tables.values.gold_tables}}",
        "concurrency": 4,
        "task": {
          "task_key": "process_gold_table",
          "run_if": "ALL_SUCCESS",
          "notebook_task": {
            "notebook_path": "/Workspace/Users/chittoriarocks@gmail.com/Gold_files/controllers/process_gold_table",
            "base_parameters": {
              "gold_table_name": "{{input}}"
            },
            "source": "WORKSPACE"
          },
          "max_retries": 3,
          "min_retry_interval_millis": 60000,
          "retry_on_timeout": false,
          "disable_auto_optimization": false,
          "timeout_seconds": 0,
          "email_notifications": {},
          "webhook_notifications": {},
          "disabled": false
        }
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {},
      "disabled": false
    }
  ],
  "queue": {
    "enabled": true
  },
  "performance_target": "PERFORMANCE_OPTIMIZED"
}